# Workers static assets headers — https://developers.cloudflare.com/workers/static-assets/headers/

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; base-uri 'self'; form-action 'self'

# Admin UI: never cache, never frame — matches the headers the Worker used to
# send when it served this page inline. (/admin redirects to /admin/, so the
# splat rule covers the page and its assets.)
/admin
  Cache-Control: no-store
  X-Frame-Options: DENY
/admin/*
  Cache-Control: no-store
  X-Frame-Options: DENY

# Vendored Swiper bundle is versioned by hand — safe to cache hard.
/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# Revalidate rather than cache blind: these filenames aren't fingerprinted, so
# a max-age here doesn't just delay an update, it can pair new HTML with a
# stale script — /demo breaks outright when demo.js and site.css disagree.
# "no-cache" still caches, it just makes the browser confirm with the ETag
# (which Workers generates per asset), so the usual answer is a 304.
# Raise this to a long max-age if these ever get content hashes in the name.
/assets/*
  Cache-Control: no-cache
